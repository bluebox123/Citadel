# Copy this file to .env and fill in real values. NEVER commit .env to git.

# 32-byte (256-bit) HMAC secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
GUARDRAIL_SECRET_KEY=replace_with_64_char_hex_secret

# Target LLM API endpoint
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace_with_real_key

# Server
HOST=0.0.0.0
PORT=8000
ENV=development   # development | production
