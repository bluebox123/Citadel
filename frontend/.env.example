# GuardRail-AI Frontend Environment Variables

# Backend Gateway URL (HMAC-signed requests)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000/api/v1/gateway

# HMAC-SHA256 Secret Key (must match backend)
NEXT_PUBLIC_HMAC_SECRET_KEY=your-256-bit-hex-key-here

# Application Environment
NEXT_PUBLIC_ENV=development

# Debug mode for development
NEXT_PUBLIC_DEBUG=false
